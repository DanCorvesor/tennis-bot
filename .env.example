# LTA / ClubSpark credentials
LTA_USERNAME=
LTA_PASSWORD=
CLUBSPARK_EMAIL=

# Notification method: "ntfy" or "twilio"
NOTIFY_METHOD=ntfy
NTFY_TOPIC=my-tennis-bot

# Twilio credentials (only needed if NOTIFY_METHOD=twilio)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=+14155238886
# SMS_RECIPIENTS=Alice:+447000000000,Bob:+447000000001

# Payment fallback (optional; only if basket link method fails)
# CARD_NUMBER=
# CARD_EXPIRY=
# CARD_CVV=
# CARD_NAME=

# Bot config
COURTS=https://clubspark.lta.org.uk/SouthwarkPark,https://clubspark.lta.org.uk/BrunswickPark,https://clubspark.lta.org.uk/BurgessParkSouthwark
PREFERRED_TIMES=10:00,11:00,09:00
BOOKING_DAYS=Saturday,Sunday
SLOT_DURATION_HOURS=1
RELEASE_HOUR=20

# Session cookie storage location
SESSION_STATE_PATH=.state/session.json
