# LTA / ClubSpark credentials
LTA_USERNAME=
LTA_PASSWORD=
CLUBSPARK_EMAIL=

# Notification method: "ntfy" or "twilio"
NOTIFY_METHOD=ntfy
NTFY_TOPIC=my-tennis-bot

# Twilio credentials (only needed if NOTIFY_METHOD=twilio)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=+14155238886
# SMS_RECIPIENTS=Alice:+447000000000,Bob:+447000000001

# Payment fallback (optional; only if basket link method fails)
# CARD_NUMBER=
# CARD_EXPIRY=
# CARD_CVV=
# CARD_NAME=

# Bot config
COURTS=https://clubspark.lta.org.uk/SouthwarkPark,https://clubspark.lta.org.uk/BrunswickPark,https://clubspark.lta.org.uk/BurgessParkSouthwark
SLOT_DURATION_HOURS=1
RELEASE_HOUR=20

# Schedule: "Days=times;Days=times;..." — groups are checked in order (first = highest priority).
# Within each group, times are checked across all days before moving to the next time.
# Example below: weekend mornings first, then Sat afternoon, Sun afternoon, weekday evenings.
BOOKING_SCHEDULE=Saturday,Sunday=10:00,11:00,09:00;Saturday=14:00,15:00,16:00,17:00,18:00;Sunday=14:00,15:00,16:00,17:00,18:00,19:00,20:00;Monday,Tuesday,Wednesday,Thursday,Friday=18:00,19:00,20:00,21:00

# Legacy format (used if BOOKING_SCHEDULE is not set):
# PREFERRED_TIMES=10:00,11:00,09:00
# BOOKING_DAYS=Saturday,Sunday

# Session cookie storage location
SESSION_STATE_PATH=.state/session.json
